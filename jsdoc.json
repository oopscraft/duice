{
  "tags": {
    "allowUnknownTags": false
  },
  "source": {
    "include": ["./src/duice.js"]
  },
  "plugins": [
    "plugins/markdown"
  ],
  "opts": {
    "template": "node_modules/docdash",
    "destination": "./doc",
    "readme": "./README.md",
    "encoding": "utf8",
    "recurse": true,
    "verbose": true
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false,
    "default": {
      "outputSourceFiles": true
    }
  }, 
  "docdash": {
    "static": false,
    "sort": false
  }
}