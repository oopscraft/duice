{
  "tags": {
    "allowUnknownTags": false
  },
  "source": {
    "include": ["./src/duice.js"]
  },
  "plugins": [
    "plugins/markdown"
  ],
  "opts": {
    "template": "doc-tmpl",
    "destination": "./doc",
    "readme": "./README.md",
    "encoding": "utf8",
    "recurse": true,
    "verbose": true
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false,
    "default": {
      "outputSourceFiles": true,
      "useLongnameInNav": true
    }
  }, 
  "docdash": {
	    "static": false,
	    "sort": false,
	    "sectionOrder": [
	         "Namespaces",
	         "Classes",
	         "Modules",
	         "Externals",
	         "Events",
	         "Mixins",
	         "Tutorials",
	         "Interfaces"
	    ],
        "meta": {  
            "title": "DUICE(Data-oriented UI Compnent Engin",
            "description": "Data oriented javascript UI Component Library",
            "keyword": "javascript UI Component"
        },
		"private": true,
	    "collapse": true
  	}
}
