{
  "tags": {
    "allowUnknownTags": false
  },
  "source": {
    "include": ["./src/duice.js"]
  },
  "plugins": [
    "plugins/markdown",
	"node_modules/jsdoc-plantuml"
  ],
  "opts": {
    "template": "doc-tmpl",
    "destination": "./doc",
    "readme": "./README.md",
    "encoding": "utf8",
    "recurse": true,
    "verbose": true
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false,
    "default": {
      "outputSourceFiles": true,
      "useLongnameInNav": true
    }
  },
  "plantuml":{
	"puml":{
		"create":true,
   		"destination":"./doc/puml"
	},
	"images":{
		"create":true,
		"destination":"./doc/images",
		"defaultFormat":"png"
	}
  },
  "docdash": {
	    "static": false,
	    "sort": false,
	    "sectionOrder": [
	         "Namespaces",
	         "Classes",
	         "Modules",
	         "Externals",
	         "Events",
	         "Mixins",
	         "Tutorials",
	         "Interfaces"
	    ],
        "meta": {  
            "title": "DUICE (Data-oriented javascript UI Compnent Engine)",
            "description": "Data-oriented javascript UI Component Library",
            "keyword": "javascript UI Component Library"
        },
		"private": true,
	    "collapse": true
  	}
}
