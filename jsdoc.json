{
  "tags": {
    "allowUnknownTags": false
  },
  "source": {
    "include": ["./src/duice.js"]
  },
  "plugins": [
    "plugins/markdown"
  ],
  "opts": {
    "template": "doc-tmpl",
    "destination": "./doc",
    "readme": "./README.md",
    "encoding": "utf8",
    "recurse": true,
    "verbose": true
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false,
    "default": {
      "outputSourceFiles": true
    }
  }, 
  "docdash": {
    "static": false,
    "sort": false,
    "openGraph": {                 
        "title": "DUICE",               
        "type": "website",         
        "image": "",               
        "site_name": "DUICE",           
        "url": "http://duice.oopscraft.net"
    },
    "collapse": false
  }
}